{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/index.ts",
    "src/postinstall.ts",
    "src/cli/index.ts",
    "src/cli/setup.ts",
    "src/install/**/*",
    "src/python/**/*"
  ],
  "exclude": ["node_modules", "dist", "tests"]
}
